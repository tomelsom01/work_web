<section class="faq-section py-5">
  <div class="container">

    <div class="text-center mb-5">
      <h2>FAQ</h2>
      <p class="text-muted">
        A few common questions about mobile massage appointments
      </p>
    </div>

    <div class="accordion" id="homepageFaq">

      <!-- Prepare for Massage -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faqOne">
            How should I prepare for a massage?
          </button>
        </h2>

        <div id="faqOne" class="accordion-collapse collapse show" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <ul>
              <li>Please double-check your address and confirm you have booked the correct treatment.</li>
              <li>Ensure there is enough space for a massage table (approximately 2m x 3m) with room to move around.</li>
              <li>Choose a comfortable room that is easy to access and warm enough for treatment.</li>
              <li>Prepare two large towels and one small towel for the headrest.</li>
              <li>If possible, take a shower beforehand to help relax the muscles.</li>
              <li>You may also mention any health conditions, allergies, parking instructions or building access details beforehand.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Coverage Area -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faqTwo">
            What areas do you cover?
          </button>
        </h2>

        <div id="faqTwo" class="accordion-collapse collapse" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <p>Tom is based in South London and covers:</p>

            <ul>
              <li>South London</li>
              <li>Surrey – Guildford, Farnborough, Woking, Reigate, Banstead and Tandridge</li>
              <li>Berkshire – Slough, Windsor and Maidenhead</li>
            </ul>

            <p>If you are outside these areas, please contact Tom with your address and a travel quote can be provided.</p>
          </div>
        </div>
      </div>

      <!--opening times -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faqThree">
            What are your opening hours?
          </button>
        </h2>

        <div id="faqThree" class="accordion-collapse collapse" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <p>I offer appointments Monday to Friday, between 10:00am and 10:00pm.</p>
            <p>Evening appointments are available, but I recommend booking in advance as these are the most popular times.</p>
          </div>
        </div>
      </div>

      <!-- Cancellation Policy -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faqFour">
            What is your cancellation policy?
          </button>
        </h2>

        <div id="faqFour" class="accordion-collapse collapse" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <p>
              Appointments can be cancelled or rescheduled free of charge up to
              <strong>24 hours before your booking</strong>.
            </p>

            <p>
              Cancellations made within 24 hours, or missed appointments, may be
              charged the full treatment fee. This protects appointment time that
              has been reserved specifically for you.
            </p>

            <p>
              If you need to make a change, please contact Tom as soon as possible
              and every effort will be made to accommodate you.
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Link to Full FAQ -->
    <div class="text-center mt-4">
      <a href="/faq" class="btn btn-outline-dark">
        View All Questions
      </a>
    </div>

  </div>
</section>
