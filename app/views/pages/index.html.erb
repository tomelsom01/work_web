    <!-- RIGHT COLUMN: Contact Form -->
    <div class="col-lg-8">
      <div class="card shadow-sm border-0">
        <div class="card-body pt-4 pb-2 px-4">
          <h4 class="mb-4 text-center">Send a Message</h4>

          <%= form_with url: contact_path, method: :post do |f| %>

            <div class="mb-3">
              <%= f.label :name, class: "form-label fw-semibold" %>
              <%= f.text_field :name, class: "form-control form-control-lg", placeholder: "Your name", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-semibold" %>
              <%= f.email_field :email, class: "form-control form-control-lg", placeholder: "your@email.com", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :phone, "Telephone", class: "form-label fw-semibold" %>
              <%= f.telephone_field :phone, class: "form-control", placeholder: "07...", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :address, "Address / Location", class: "form-label fw-semibold" %>
              <%= f.text_field :address, class: "form-control", placeholder: "Where the treatment will take place", required: true %>
            </div>

            <div class="mb-4">
              <%= f.label :message, class: "form-label fw-semibold" %>
              <%= f.text_area :message, class: "form-control", rows: 5, placeholder: "To book, please include your preferred date(s) & time(s), treatment type and how can I help?", required: true %>
            </div>

            <div class="d-grid pb-4">
              <%= f.submit "Send Message", class: "btn btn-dark btn-lg" %>
            </div>

          <% end %>
        </div>
      </div>
    </div>
  </div>
