<section class="faq-section py-5">
  <div class="container">

    <div class="text-center mb-5">
      <h2>FAQ</h2>
      <p class="text-muted">
        A few common questions about mobile massage appointments
      </p>
    </div>

    <div class="accordion" id="homepageFaq">

      <!-- Prepare for Massage -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faqOne">
            How should I prepare for a massage?
          </button>
        </h2>

        <div id="faqOne" class="accordion-collapse collapse show" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <ul>
              <li>Please double-check your address and confirm you have booked the correct treatment.</li>
              <li>Ensure there is enough space for a massage table (approximately 2m x 3m) with room to move around.</li>
              <li>Choose a comfortable room that is easy to access and warm enough for treatment.</li>
              <li>Prepare two large towels and one small towel for the headrest.</li>
              <li>If possible, take a shower beforehand to help relax the muscles.</li>
              <li>You may also mention any health conditions, allergies, parking instructions or building access details beforehand.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Coverage Area -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faqTwo">
            What areas do you cover?
          </button>
        </h2>

        <div id="faqTwo" class="accordion-collapse collapse" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <p>Tom is based in South London and covers:</p>

            <ul>
              <li>South London</li>
              <li>London Bridge</li>
              <li>Canary Wharf</li>
              <li>Kensington</li>
              <li>Chelsea</li>
            </ul>

            <p>If you are outside these areas, please contact Tom with your address and a travel quote can be provided.</p>
          </div>
        </div>
      </div>

      <!--opening times -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faqThree">
            What are your opening hours?
          </button>
        </h2>

        <div id="faqThree" class="accordion-collapse collapse" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <p>I offer appointments Monday to Friday, between 10:00am and 10:00pm.</p>
            <p>Evening appointments are available, but I recommend booking in advance as these are the most popular times.</p>
          </div>
        </div>
      </div>

      <!-- Cancellation Policy -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faqFour">
            What is your cancellation policy?
          </button>
        </h2>

        <div id="faqFour" class="accordion-collapse collapse" data-bs-parent="#homepageFaq">
          <div class="accordion-body">
            <p>
              Appointments can be cancelled or rescheduled free of charge up to
              <strong>24 hours before your booking</strong>.
            </p>

            <p>
              Cancellations made within 24 hours, or missed appointments, may be
              charged the full treatment fee. This protects appointment time that
              has been reserved specifically for you.
            </p>

            <p>
              If you need to make a change, please contact Tom as soon as possible
              and every effort will be made to accommodate you.
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Link to Full FAQ -->
    <div class="text-center mt-4">
      <a href="/faq" class="btn btn-outline-dark">
        View All Questions
      </a>
    </div>

  </div>
</section>
<div class="container py-5">
  <div class="row justify-content-center" >
    <!-- LEFT COLUMN: Contact Info -->
    <div class="col-lg-4 mb-4">
      <div class="p-4 rounded shadow-sm h-100 d-flex flex-column justify-content-between getintouchbox">
        <div>
          <h4 class="mb-3">Get in Touch</h4>

          <p class="mb-2">
            <strong>Phone:</strong> <a href="tel:07356014431" class="text-decoration-none">0735 601 4431</a>
          </p>
          <p class="mb-3">
            <strong>Email:</strong> <a href="mailto:tom@mobilemassagelondon.com" class="text-decoration-none">tom@mobilemassagelondon.com</a>
          </p>

          <p class="text-muted mb-3">Have a question or want to book a treatment? Reach out today.</p>

          <!-- Reassurance / Selling Points -->
          <ul class="list-unstyled text-success mb-0">
            <li class="mb-2">✅ Fully mobile treatments in South London</li>
            <li class="mb-2">✅ 19 years of experience</li>
            <li class="mb-2">✅ Tailored sessions for your needs</li>
            <li>✅ Professional, safe, and results-focused</li>
          </ul>
        </div>

        <!-- Optional CTA / testimonial -->
        <div class="mt-4 text-muted fst-italic">
          <p>“I feel 100% better after every session!” – Sarah T.</p>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN: Contact Form -->
    <div class="col-lg-8" id="booking">
      <div class="card shadow-sm border-0">
        <div class="card-body pt-4 pb-2 px-4">
          <h4 class="mb-4 text-center">Send a Message</h4>

          <%= form_with url: contact_path, method: :post, id: "contactForm" do |f| %>

            <%= f.hidden_field :treatment, id: "treatmentField" %>

            <div class="mb-3">
              <%= f.label :name, class: "form-label fw-semibold" %>
              <%= f.text_field :name, class: "form-control form-control-lg", placeholder: "Your name", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-semibold" %>
              <%= f.email_field :email, class: "form-control form-control-lg", placeholder: "your@email.com", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :phone, "Telephone", class: "form-label fw-semibold" %>

              <%= f.telephone_field :phone,
                class: "form-control",
                placeholder: "07... or +44...",
                id: "phone",
                required: true %>

              <div id="phoneError" class="error-message"></div>
            </div>

            <div class="mb-3">
              <%= f.label :address, "Address / Location", class: "form-label fw-semibold" %>
              <%= f.text_field :address, class: "form-control", placeholder: "Where the treatment will take place", required: true %>
            </div>

            <div class="mb-4">
              <%= f.label :message, class: "form-label fw-semibold" %>
              <%= f.text_area :message,
              id: "messageField",
              class: "form-control",
              rows: 5,
              placeholder: "To book, please include your preferred date(s) & time(s)...",
              required: true %>
            </div>

            <div class="d-grid pb-4">
              <%= f.submit "Send Message", class: "btn btn-dark btn-lg" %>
            </div>

          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
