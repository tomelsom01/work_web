<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Mobile Massage London" %></title>
    <%= favicon_link_tag 'mobilemassagelondon.png', type: 'image/png' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Mobile Massage London">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness",
  "@id": "https://mobilemassagelondon.com/#business",

  "name": "Mobile Massage London",
  "url": "https://mobilemassagelondon.com",

  "logo": "<%= image_url('mobilemassagelondon.png') %>",
  "image": "https://res.cloudinary.com/daaxwngzv/image/upload/v1772617011/ChatGPT_Image_Mar_4_2026_09_35_25_AM_hk8haj.png",

  "description": "Mobile sports massage therapist in London specialising in deep tissue, recovery, and injury prevention. Treatments delivered to your home, office, or hotel across Central London.",

  "telephone": "+447356014431",
  "email": "tom@mobilemassagelondon.com",

  "priceRange": "££",

  "areaServed": [
    { "@type": "City", "name": "London" },
    { "@type": "AdministrativeArea", "name": "Kensington and Chelsea" },
    { "@type": "Place", "name": "Canary Wharf, London" },
    { "@type": "Place", "name": "London Bridge, London" }
  ],

  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+447356014431",
    "contactType": "customer service",
    "areaServed": "GB"
  },

  "serviceType": [
    "Sports Massage",
    "Deep Tissue Massage",
    "Mobile Massage Therapy"
  ],

  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "10:00",
      "closes": "22:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Saturday","Sunday"],
      "opens": "09:00",
      "closes": "18:00"
    }
  ]
}



</script>
<meta property="og:title" content="Mobile Massage London">
<meta property="og:description" content="Mobile sports massage therapy in London. We come to your home, office or hotel.">
<meta property="og:image" content="https://res.cloudinary.com/daaxwngzv/image/upload/v1772617011/ChatGPT_Image_Mar_4_2026_09_35_25_AM_hk8haj.png">
<meta property="og:url" content="https://mobilemassagelondon.com">
<meta property="og:type" content="website">


<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Mobile Massage London">
<meta name="twitter:description" content="Mobile sports massage therapy in London. Book a professional massage at home.">
<meta name="twitter:image" content="https://res.cloudinary.com/daaxwngzv/image/upload/v1772617011/ChatGPT_Image_Mar_4_2026_09_35_25_AM_hk8haj.png">
  </head>

  <body>
    <%= render partial: "layouts/partials/nav" %>
    <% flash.each do |type, message| %>
      <div class="alert <%= type == "notice" ? "alert-success" : "alert-danger" %> alert-dismissible fade show m-3" role="alert">
      <%= message %>
       <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
    <%= yield %>
    <div id="cookie-banner" class="cookie-banner alert alert-light border-top shadow-sm fixed-bottom mb-0 text-center">
      <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">

        <span class="mb-2 mb-md-0">
          This website uses cookies to improve your experience.
          <a href="/privacy" class="ms-1">Learn more</a>
        </span>

        <button id="accept-cookies" class="btn btn-dark btn-sm">
          Accept
        </button>

     </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Auto-hide flash script -->
    <script>
      setTimeout(() => {
        document.querySelectorAll('.alert').forEach(el => el.remove());
      }, 5000); // hides after 5 seconds
    </script>
  </body>
</html>
